# DigitalOcean App Platform - Environment Variables
# Set các giá trị này trên DO dashboard → App Settings → Environment Variables

# Database (DigitalOcean Managed PostgreSQL sẽ inject DATABASE_URL tự động)
DATABASE_URL=postgresql://user:password@host:5432/dbname
USE_SQLITE=false

# JWT
JWT_SECRET_KEY=change-this-to-a-strong-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Sepay Payment
SEPAY_APP_ID=your-sepay-app-id
SEPAY_SECRET_KEY=your-sepay-secret-key
SEPAY_WEBHOOK_SECRET=your-webhook-secret

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# CORS - set domain frontend sau khi deploy
CORS_ORIGINS=https://your-frontend-app.ondigitalocean.app
